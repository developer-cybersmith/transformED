# ============================================================
# HIE â€” Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- App ----
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=           # Settings > API > JWT Settings > JWT Secret

# ---- Railway Redis ----
REDIS_URL=redis://default:password@containers-us-west-xxx.railway.app:6379

# ---- OpenAI ----
OPENAI_API_KEY=sk-...

# ---- Anthropic (Phase 2 â€” tutor Q&A) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- ElevenLabs (TTS primary) ----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=           # The voice ID to use for narration

# ---- HeyGen (Avatar â€” cached intro/outro) ----
HEYGEN_API_KEY=
HEYGEN_INTRO_ASSET_PATH=       # Supabase Storage path: avatars/intro.mp4
HEYGEN_OUTRO_ASSET_PATH=       # Supabase Storage path: avatars/outro.mp4

# ---- Langfuse (LLM observability, self-hosted) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3010

# ---- Sentry ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- PostHog (product analytics) ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Stripe (payments) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- Cost ceilings (env vars = tunable without redeploy) ----
MAX_LESSON_COST_USD=3.00
MAX_DAILY_SPEND_PER_USER_USD=10.00

# ---- LLM model allocation (per PRD Â§6.4) ----
LLM_LESSON_PLANNER=gpt-4o
LLM_SLIDE_GENERATOR=gpt-4o
LLM_MINI=gpt-4o-mini

# ---- CES weights (tunable â€” calibrate after 20 sessions, per PRD Â§11) ----
CES_WEIGHT_QUIZ=0.35
CES_WEIGHT_TEACHBACK=0.25
CES_WEIGHT_BEHAVIORAL=0.20
CES_WEIGHT_HEAD_POSE=0.12
CES_WEIGHT_BLINK=0.08
CES_THRESHOLD=50.0

# ---- Intervention limits (per PRD Â§10 guard rules) ----
INTERVENTION_COOLDOWN_SECONDS=120
MAX_DISTRACTION_PER_SESSION=3

