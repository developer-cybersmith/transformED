# ============================================================
# HIE — Root .gitignore
# Sub-project gitignores (apps/api, apps/web) handle their
# own framework-specific patterns. This file covers repo-wide
# and personal/generated exclusions.
# ============================================================

# ---- Personal dev context (NEVER push) ----
_bmad/config.user.toml
_bmad-output/
docs/dev2-sprint-tracker.md
docs/dev2-frontend-role.md
docs/dev1-pydantic-schemas-task.md
docs/dev3-*.md
docs/dev4-*.md

# ---- Environment variables ----
.env
.env.*
!.env.example

# ---- Node / pnpm ----
node_modules/
.pnpm-store/
.pnp
.pnp.*
# npm lockfile should not exist in a pnpm workspace — ignore if created by accident
package-lock.json
**/package-lock.json

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.so
.venv/
venv/
env/
.uv/
*.egg-info/
dist/
build/

# ---- Next.js ----
.next/
out/
*.tsbuildinfo
next-env.d.ts

# ---- Build / coverage ----
/coverage
htmlcov/
.pytest_cache/
.coverage
.coverage.*
junit*.xml

# ---- OS ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- IDE ----
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Claude Code local settings ----
.claude/settings.local.json
