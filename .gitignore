# ============================================================
# TransformED AI — Root .gitignore
# Covers the full monorepo (Python API + Next.js Web + shared)
# ============================================================

# ---- Environment & secrets (NEVER commit) ----
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.stackdump

# ---- Editor / IDE ----
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.history/

# ---- Personal / generated (NEVER push) ----
_bmad/config.user.toml
_bmad-output/

# ---- Node / pnpm ----
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# npm lockfile must not exist in a pnpm workspace
package-lock.json
**/package-lock.json

# ---- Next.js ----
apps/web/.next/
apps/web/out/
apps/web/.vercel/
apps/web/*.tsbuildinfo
apps/web/next-env.d.ts

# ---- TypeScript ----
*.tsbuildinfo

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
.venv/
venv/
env/
ENV/
.uv/
*.egg-info/
*.egg
dist/
build/
wheels/
pip-wheel-metadata/
.installed.cfg
# Anchored to repo root — unanchored "lib/"/"lib64/" would also match
# apps/web/src/lib/ (Next.js source) and apps/web/src/__tests__/lib/,
# silently hiding real frontend files from git. Neither exists at the
# repo root in this monorepo layout, so anchoring is a no-op for the
# legacy-Python-build-artifact case this was meant for.
/lib/
/lib64/
parts/
sdist/
var/
*.manifest
*.spec

# ---- Python tools ----
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ---- Test & coverage ----
.pytest_cache/
.coverage
.coverage.*
coverage/
htmlcov/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.tox/
junit*.xml

# ---- Supabase local ----
supabase/.branches/
supabase/.temp/
supabase/seed.sql

# ---- Redis ----
dump.rdb
*.rdb

# ---- Docker ----
.docker/

# ---- Langfuse (self-hosted local) ----
langfuse.db
langfuse-data/

# ---- Build / dist outputs ----
dist/
build/
out/

# ---- Logs ----
logs/
*.log
*.log.*

# ---- Temporary files ----
*.tmp
*.temp
.cache/
tmp/

# ---- Claude Code local settings ----
.claude/settings.local.json

# ---- Playwright MCP (local browser automation artifacts) ----
.playwright-mcp/

# ---- Local-only developer docs (not for the repo) ----
docs/LOCAL_DEV_SETUP.md
