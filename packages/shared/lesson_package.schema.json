{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hieiq.ai/schemas/lesson_package.schema.json",
  "title": "LessonPackage",
  "description": "JSON Schema for a fully-generated HIE lesson package stored as JSONB in lessons.content.",
  "type": "object",
  "required": [
    "lesson_id",
    "book_id",
    "chapter_id",
    "created_at",
    "metadata",
    "segments",
    "glossary"
  ],
  "additionalProperties": false,
  "properties": {
    "lesson_id": {
      "type": "string",
      "format": "uuid"
    },
    "book_id": {
      "type": "string",
      "format": "uuid"
    },
    "chapter_id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "$ref": "#/definitions/LessonMetadata"
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Segment"
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/GlossaryEntry"
      }
    }
  },
  "definitions": {
    "LessonMetadata": {
      "type": "object",
      "required": [
        "title",
        "subject",
        "total_segments",
        "estimated_duration_mins",
        "complexity_level"
      ],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "total_segments": { "type": "integer", "minimum": 1 },
        "estimated_duration_mins": { "type": "number", "minimum": 0 },
        "complexity_level": { "type": "string" }
      }
    },
    "SegmentComplexity": {
      "type": "object",
      "required": [
        "level",
        "cognitive_load",
        "abstraction_level",
        "prerequisite_concepts",
        "narration_style",
        "quiz_difficulty",
        "intervention_sensitivity"
      ],
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "cognitive_load": { "type": "string" },
        "abstraction_level": { "type": "string" },
        "prerequisite_concepts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "narration_style": { "type": "string" },
        "quiz_difficulty": { "type": "string" },
        "intervention_sensitivity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "Slide": {
      "type": "object",
      "required": ["slide_id", "title", "bullets", "image_url", "fallback_image_url"],
      "additionalProperties": false,
      "properties": {
        "slide_id": { "type": "string" },
        "title": { "type": "string" },
        "bullets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "image_url": {
          "oneOf": [{ "type": "string", "format": "uri" }, { "type": "null" }]
        },
        "fallback_image_url": {
          "oneOf": [{ "type": "string", "format": "uri" }, { "type": "null" }]
        }
      }
    },
    "NarrationTimestamp": {
      "type": "object",
      "required": ["slide_id", "start_ms", "end_ms"],
      "additionalProperties": false,
      "properties": {
        "slide_id": { "type": "string" },
        "start_ms": { "type": "integer", "minimum": 0 },
        "end_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "Narration": {
      "type": "object",
      "required": ["script", "audio_url", "audio_provider", "timestamps"],
      "additionalProperties": false,
      "properties": {
        "script": { "type": "string" },
        "audio_url": { "type": "string" },
        "audio_provider": {
          "type": "string",
          "enum": ["sarvam", "azure", "browser"]
        },
        "timestamps": {
          "type": "array",
          "items": { "$ref": "#/definitions/NarrationTimestamp" }
        }
      }
    },
    "QuizQuestion": {
      "type": "object",
      "required": [
        "question_id",
        "type",
        "question",
        "options",
        "correct_index",
        "explanation",
        "difficulty"
      ],
      "additionalProperties": false,
      "properties": {
        "question_id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["mcq", "concept_check"]
        },
        "question": { "type": "string" },
        "options": {
          "type": "array",
          "minItems": 4,
          "items": { "type": "string" }
        },
        "correct_index": {
          "type": "integer",
          "minimum": 0
        },
        "explanation": { "type": "string" },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        }
      }
    },
    "JargonEntry": {
      "type": "object",
      "required": ["term", "definition"],
      "additionalProperties": false,
      "properties": {
        "term": { "type": "string" },
        "definition": { "type": "string" }
      }
    },
    "InterventionMessages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "string" }
    },
    "SegmentInterventions": {
      "type": "object",
      "required": ["distraction", "confusion", "fatigue"],
      "additionalProperties": false,
      "properties": {
        "distraction": { "$ref": "#/definitions/InterventionMessages" },
        "confusion": { "$ref": "#/definitions/InterventionMessages" },
        "fatigue": { "$ref": "#/definitions/InterventionMessages" }
      }
    },
    "Segment": {
      "type": "object",
      "required": [
        "segment_id",
        "segment_index",
        "title",
        "summary",
        "complexity",
        "slides",
        "narration",
        "quiz",
        "teachback_prompt",
        "jargon",
        "interventions"
      ],
      "additionalProperties": false,
      "properties": {
        "segment_id": { "type": "string" },
        "segment_index": { "type": "integer", "minimum": 0 },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "complexity": { "$ref": "#/definitions/SegmentComplexity" },
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Slide" }
        },
        "narration": { "$ref": "#/definitions/Narration" },
        "quiz": {
          "type": "array",
          "items": { "$ref": "#/definitions/QuizQuestion" }
        },
        "teachback_prompt": { "type": "string" },
        "jargon": {
          "type": "array",
          "items": { "$ref": "#/definitions/JargonEntry" }
        },
        "interventions": { "$ref": "#/definitions/SegmentInterventions" }
      }
    },
    "GlossaryEntry": {
      "type": "object",
      "required": ["term", "definition"],
      "additionalProperties": false,
      "properties": {
        "term": { "type": "string" },
        "definition": { "type": "string" }
      }
    }
  }
}

